# ========================================
# 生产环境配置文件
# ========================================
# 使用方法：
#   1. cp .env.production .env
#   2. 编辑 .env 文件修改配置（特别是密钥和密码）
#   3. docker-compose -f docker-compose.prod.yml up -d
# ========================================

# ========================================
# 应用配置
# ========================================
# Flask 端口
FLASK_PORT=5002

# Nginx 端口
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# 应用密钥（必须修改！）
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-change-this-to-a-very-long-and-random-string-in-production

# ========================================
# 数据库配置
# ========================================
# 数据库密码（必须修改！）
# 生成命令：openssl rand -base64 32
DB_PASSWORD=change-this-password-in-production-production-strong-password

# ========================================
# Gunicorn 配置
# ========================================
# Worker 进程数（建议 = CPU核心数 * 2 + 1）
GUNICORN_WORKERS=4

# 每个 Worker 的线程数
GUNICORN_THREADS=2

# ========================================
# AI API 配置
# ========================================
# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ========================================
# 邮件配置（可选）
# ========================================
# SMTP 服务器
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@example.com

# ========================================
# Redis 配置
# ========================================
# Redis URL（通常不需要修改）
REDIS_URL=redis://redis:6379/0

# ========================================
# 日志配置
# ========================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志格式: text, json
LOG_FORMAT=json
