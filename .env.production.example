# Flask 配置
FLASK_ENV=production
FLASK_PORT=5002
FLASK_DEBUG=false

# 安全配置（请修改为随机生成的密钥）
SECRET_KEY=please-change-this-secret-key-in-production-use-python-secrets

# 数据库配置
POSTGRES_DB=examdb
POSTGRES_USER=examuser
POSTGRES_PASSWORD=please-change-this-password-in-production

# 文件上传配置
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=uploads

# 日志配置
LOG_LEVEL=INFO

# AI 配置（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 应用配置
APP_NAME=在线答题系统 v3.1
