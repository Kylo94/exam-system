# ========================================
# 开发环境配置文件
# ========================================
# 使用方法：
#   1. cp .env.example .env
#   2. 编辑 .env 文件修改配置
#   3. docker-compose up -d

# ========================================
# Flask 配置
# ========================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5002
FLASK_DEBUG=true

# 安全密钥（开发环境可使用简单密钥）
# 生产环境必须使用强密钥，生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-do-not-use-in-production

# ========================================
# 数据库配置
# ========================================
# 开发环境默认使用 PostgreSQL（Docker）
DATABASE_URL=postgresql://examuser:exam_password_123456@db:5432/examdb

# 或使用 SQLite（不推荐用于开发环境）
# DATABASE_URL=sqlite:///exam_system.db

# 数据库密码（开发环境默认值）
DB_PASSWORD=exam_password_123456

# ========================================
# AI API 配置
# ========================================
# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ========================================
# Redis 配置
# ========================================
REDIS_URL=redis://redis:6379/0

# ========================================
# 文件上传配置
# ========================================
# 最大上传文件大小（字节）
# 50MB = 52428800
MAX_CONTENT_LENGTH=52428800

# 上传文件夹路径
UPLOAD_FOLDER=uploads

# 允许的文件扩展名
ALLOWED_EXTENSIONS=docx,doc,pdf,jpg,jpeg,png,gif

# ========================================
# 应用配置
# ========================================
APP_NAME="在线答题系统"
DEBUG=true
TESTING=false

# ========================================
# 会话配置
# ========================================
# 会话有效期（秒）
# 24小时 = 86400
PERMANENT_SESSION_LIFETIME=86400

# ========================================
# 日志配置
# ========================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# 日志文件路径
LOG_FILE=logs/exam_system.log

# 日志文件最大大小（字节）
LOG_MAX_BYTES=10485760

# 日志备份数量
LOG_BACKUP_COUNT=10

# ========================================
# 邮件配置（可选，用于通知）
# ========================================
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@example.com

# ========================================
# 安全配置
# ========================================
# CSRF 保护
WTF_CSRF_ENABLED=true
WTF_CSRF_TIME_LIMIT=None

# 文件上传安全
UPLOAD_EXTENSIONS=['docx', 'doc', 'pdf', 'jpg', 'jpeg', 'png', 'gif']
UPLOAD_MAX_SIZE=52428800

