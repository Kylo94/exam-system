# 在线答题系统 - 环境配置示例
# 复制此文件为 .env 并修改相应值

# ============ 应用配置 ============
APP_NAME="在线答题系统"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ============ 数据库配置 ============
# SQLite (开发环境)
DATABASE_URL=sqlite://./data/exam_system.db

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/exam_system

# ============ 密钥配置（生产环境必须修改）============
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ 管理员账户 ============
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# ============ 文件上传配置 ============
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# ============ CORS配置（生产环境建议限制）============
# ALLOWED_ORIGINS=http://localhost:3000,http://your-domain.com

# ============ 注意 ============
# AI配置（API Key等）请在系统管理页面 /admin/ai-configs 中配置
# 这些配置存储在数据库中，支持多账号管理
