# ========================================
# 环境配置模板
# ========================================
# 使用方法：
#   Docker 生产部署：
#     1. 复制此文件为 .env: cp .env.example .env
#     2. 修改 SECRET_KEY、ADMIN_PASSWORD、POSTGRES_PASSWORD 等敏感配置
#     3. 运行: docker-compose up -d
#
#   本地开发：
#     1. 复制此文件为 .env: cp .env.example .env
#     2. 将 FLASK_ENV 改为 development，FLASK_DEBUG 改为 true
#     3. 将 DATABASE_URL 改为 SQLite: DATABASE_URL=sqlite:///instance/exam.db
#     4. 运行: python run.py

# ========================================
# Flask 配置（Docker 生产环境）
# ========================================
FLASK_APP=run.py
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5002
FLASK_DEBUG=false

# 安全密钥
# 生产环境必须使用强密钥，生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_secret_key_in_production

# ========================================
# 管理员账户配置
# ========================================
# 系统启动时会自动创建管理员账户（如果不存在）
# 生产环境请务必修改默认密码！
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_in_production
ADMIN_EMAIL=admin@example.com

# ========================================
# 数据库配置（Docker 生产环境）
# ========================================
# Docker 生产环境使用 PostgreSQL
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# 本地开发使用 SQLite（请取消注释并修改）
# DATABASE_URL=sqlite:///instance/exam.db

# ========================================
# PostgreSQL 数据库配置
# ========================================
POSTGRES_DB=examdb
POSTGRES_USER=examuser
POSTGRES_PASSWORD=change_this_password_in_production

# ========================================
# 文件上传配置
# ========================================
# 最大上传文件大小（字节）
# 50MB = 52428800
MAX_CONTENT_LENGTH=52428800

# 上传文件夹路径
UPLOAD_FOLDER=uploads

# 允许的文件扩展名
ALLOWED_EXTENSIONS=docx,doc,pdf,jpg,jpeg,png,gif

# ========================================
# 应用配置
# ========================================
APP_NAME="在线答题系统"
DEBUG=false
TESTING=false

# ========================================
# 会话配置
# ========================================
# 会话有效期（秒）
# 24小时 = 86400
PERMANENT_SESSION_LIFETIME=86400

# ========================================
# 日志配置
# ========================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/exam_system.log

# 日志文件最大大小（字节）
LOG_MAX_BYTES=10485760

# 日志备份数量
LOG_BACKUP_COUNT=10

# ========================================
# 安全配置
# ========================================
# CSRF 保护
WTF_CSRF_ENABLED=true
WTF_CSRF_TIME_LIMIT=None

# 文件上传安全
UPLOAD_EXTENSIONS=['docx', 'doc', 'pdf', 'jpg', 'jpeg', 'png', 'gif']
UPLOAD_MAX_SIZE=52428800

# ========================================
# Gunicorn 配置（生产环境）
# ========================================
# Worker 进程数（建议 = CPU核心数 * 2 + 1）
GUNICORN_WORKERS=4

# 每个 Worker 的线程数
GUNICORN_THREADS=2
