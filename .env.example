# ========================================
# 在线答题系统 v3.0 - 环境变量配置模板
# ========================================
# 部署时请复制此文件为 .env 并修改相应配置
# 命令: cp .env.example .env

# ========================================
# Flask 配置
# ========================================
FLASK_APP=run.py
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5002

# 安全密钥 - 生产环境必须使用强密钥
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# ========================================
# 数据库配置
# ========================================
# SQLite（开发环境）
DATABASE_URL=sqlite:///exam_system.db

# PostgreSQL（生产环境推荐）
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# DATABASE_URL=postgresql://examuser:password@localhost:5432/examdb

# ========================================
# 文件上传配置
# ========================================
# 最大上传文件大小（字节）
# 16MB = 16777216
# 20MB = 20971520
# 50MB = 52428800
MAX_CONTENT_LENGTH=52428800

# 上传文件夹路径
UPLOAD_FOLDER=uploads

# 允许的文件扩展名
ALLOWED_EXTENSIONS=.docx,.pdf,.txt

# ========================================
# Redis 配置（可选，用于缓存）
# ========================================
REDIS_URL=redis://localhost:6379/0

# ========================================
# 应用配置
# ========================================
APP_NAME="在线答题系统"
DEBUG=False
TESTING=False

# ========================================
# 会话配置
# ========================================
# 会话有效期（秒）
# 24小时 = 86400
PERMANENT_SESSION_LIFETIME=86400

# ========================================
# 日志配置
# ========================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/exam_system.log

# 日志文件最大大小（字节）
LOG_MAX_BYTES=10485760

# 日志备份数量
LOG_BACKUP_COUNT=10

# ========================================
# 邮件配置（可选，用于通知）
# ========================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@exam-system.com

# ========================================
# 安全配置
# ========================================
# CSRF 保护
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=None

# 文件上传安全
UPLOAD_EXTENSIONS=['docx', 'pdf', 'txt']
UPLOAD_MAX_SIZE=52428800

# ========================================
# 第三方服务配置
# ========================================
# 图床服务（可选）
IMAGE_UPLOAD_SERVICE=local
IMAGE_UPLOAD_URL=
IMAGE_UPLOAD_TOKEN=

