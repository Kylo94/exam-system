# ========================================
# 环境配置模板
# ========================================
# 使用方法：
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 根据需要修改配置
#   3. 本地开发直接运行: python run.py
#   4. Docker 部署: docker-compose up -d

# ========================================
# Flask 配置
# ========================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5002
FLASK_DEBUG=true

# 安全密钥（开发环境可使用简单密钥）
# 生产环境必须使用强密钥，生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-do-not-use-in-production

# ========================================
# 管理员账户配置
# ========================================
# 系统启动时会自动创建管理员账户（如果不存在）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@example.com

# ========================================
# 数据库配置
# ========================================
# 本地开发使用 SQLite（相对路径）
DATABASE_URL=sqlite:///instance/exam.db

# Docker 生产环境使用 PostgreSQL（通过环境变量传入）
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ========================================
# Docker 数据库配置（可选）
# ========================================
# 以下配置仅在 Docker 部署时使用
# POSTGRES_DB=examdb
# POSTGRES_USER=examuser
# POSTGRES_PASSWORD=exam_password_123456

# ========================================
# 文件上传配置
# ========================================
# 最大上传文件大小（字节）
# 50MB = 52428800
MAX_CONTENT_LENGTH=52428800

# 上传文件夹路径
UPLOAD_FOLDER=uploads

# 允许的文件扩展名
ALLOWED_EXTENSIONS=docx,doc,pdf,jpg,jpeg,png,gif

# ========================================
# 应用配置
# ========================================
APP_NAME="在线答题系统"
DEBUG=true
TESTING=false

# ========================================
# 会话配置
# ========================================
# 会话有效期（秒）
# 24小时 = 86400
PERMANENT_SESSION_LIFETIME=86400

# ========================================
# 日志配置
# ========================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# 日志文件路径
LOG_FILE=logs/exam_system.log

# 日志文件最大大小（字节）
LOG_MAX_BYTES=10485760

# 日志备份数量
LOG_BACKUP_COUNT=10

# ========================================
# 安全配置
# ========================================
# CSRF 保护
WTF_CSRF_ENABLED=true
WTF_CSRF_TIME_LIMIT=None

# 文件上传安全
UPLOAD_EXTENSIONS=['docx', 'doc', 'pdf', 'jpg', 'jpeg', 'png', 'gif']
UPLOAD_MAX_SIZE=52428800

# ========================================
# Gunicorn 配置（生产环境）
# ========================================
# Worker 进程数（建议 = CPU核心数 * 2 + 1）
GUNICORN_WORKERS=4

# 每个 Worker 的线程数
GUNICORN_THREADS=2
